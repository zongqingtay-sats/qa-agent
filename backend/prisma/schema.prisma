// Prisma schema for QA Agent — Azure SQL Server

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator frontendClient {
  provider = "prisma-client"
  output   = "../../frontend/src/generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

model TestCase {
  id              String    @id @default(uuid()) @db.NVarChar(36)
  name            String    @db.NVarChar(255)
  description     String    @db.NVarChar(Max)
  preconditions   String?   @db.NVarChar(Max)
  passingCriteria String?   @db.NVarChar(Max)
  tags            String    @default("[]") @db.NVarChar(Max) // JSON array
  flowData        String    @db.NVarChar(Max) // JSON (nodes + edges)
  status          String    @default("draft") @db.NVarChar(20)
  projectId       String?   @db.NVarChar(36)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project     Project?             @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  features    TestCaseFeature[]
  phases      TestCasePhase[]
  testRuns    TestRun[]
  assignments TestCaseAssignment[]
  comments    Comment[]

  @@map("test_cases")
}

model TestRun {
  id           String    @id @default(uuid()) @db.NVarChar(36)
  testCaseId   String    @db.NVarChar(36)
  status       String    @db.NVarChar(20) // running, passed, failed, stopped
  runBy        String?   @db.NVarChar(255) // user email or ID
  runByName    String?   @db.NVarChar(255)
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  durationMs   Int?
  environment  String?   @db.NVarChar(Max) // JSON
  totalSteps   Int       @default(0)
  passedSteps  Int       @default(0)
  failedSteps  Int       @default(0)

  testCase    TestCase     @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  stepResults StepResult[]

  @@map("test_runs")
}

model StepResult {
  id             String   @id @default(uuid()) @db.NVarChar(36)
  testRunId      String   @db.NVarChar(36)
  stepOrder      Int
  blockId        String   @db.NVarChar(36)
  blockType      String   @db.NVarChar(50)
  description    String?  @db.NVarChar(Max)
  target         String?  @db.NVarChar(Max)
  expectedResult String?  @db.NVarChar(Max)
  actualResult   String?  @db.NVarChar(Max)
  status         String   @db.NVarChar(20) // passed, failed, skipped, running
  screenshotUrl  String?  @db.NVarChar(Max) // Blob URL or base64 data URL
  errorMessage   String?  @db.NVarChar(Max)
  durationMs     Int?
  retry          Boolean  @default(false)
  executedAt     DateTime @default(now())

  testRun TestRun @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  @@map("step_results")
}

model Project {
  id          String   @id @default(uuid()) @db.NVarChar(36)
  name        String   @db.NVarChar(255)
  description String?  @db.NVarChar(Max)
  createdBy   String?  @db.NVarChar(255) // user email or ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  features        Feature[]
  phases          Phase[]
  testCases       TestCase[]
  groupVisibility GroupVisibility[]
  projectAccess   ProjectAccess[]

  @@map("projects")
}

model Feature {
  id        String   @id @default(uuid()) @db.NVarChar(36)
  projectId String   @db.NVarChar(36)
  name      String   @db.NVarChar(255)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCaseFeature[]

  @@map("features")
}

model Phase {
  id        String   @id @default(uuid()) @db.NVarChar(36)
  projectId String   @db.NVarChar(36)
  name      String   @db.NVarChar(255)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases TestCasePhase[]

  @@map("phases")
}

model TestCaseFeature {
  id         String @id @default(uuid()) @db.NVarChar(36)
  testCaseId String @db.NVarChar(36)
  featureId  String @db.NVarChar(36)

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  feature  Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([testCaseId, featureId])
  @@map("test_case_features")
}

model TestCasePhase {
  id         String @id @default(uuid()) @db.NVarChar(36)
  testCaseId String @db.NVarChar(36)
  phaseId    String @db.NVarChar(36)

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  phase    Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@unique([testCaseId, phaseId])
  @@map("test_case_phases")
}

model TestCaseAssignment {
  id         String   @id @default(uuid()) @db.NVarChar(36)
  testCaseId String   @db.NVarChar(36)
  userId     String   @db.NVarChar(255) // user email or ID
  userName   String?  @db.NVarChar(255)
  assignedAt DateTime @default(now())
  assignedBy String?  @db.NVarChar(255)

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([testCaseId, userId])
  @@map("test_case_assignments")
}

model Comment {
  id         String   @id @default(uuid()) @db.NVarChar(36)
  testCaseId String   @db.NVarChar(36)
  parentId   String?  @db.NVarChar(36)
  authorId   String   @db.NVarChar(255) // user email or ID
  authorName String?  @db.NVarChar(255)
  body       String   @db.NVarChar(Max)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  testCase TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies  Comment[] @relation("CommentReplies")

  @@map("comments")
}

model GroupVisibility {
  id        String  @id @default(uuid()) @db.NVarChar(36)
  userId    String  @db.NVarChar(255)
  projectId String  @db.NVarChar(36)
  groupType String  @db.NVarChar(20) // 'feature' or 'phase'
  groupId   String  @db.NVarChar(36) // feature_id or phase_id
  isHidden  Boolean @default(false)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId, groupType, groupId])
  @@map("group_visibility")
}

// ── NextAuth Models ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  status        String    @default("active") @db.NVarChar(20) // active | deleted

  accounts      Account[]
  sessions      Session[]
  userRole      UserRole?
  projectAccess ProjectAccess[]

  @@map("users")
}

// ── RBAC Models ──────────────────────────────────────────────

model Role {
  id             String  @id @default(uuid()) @db.NVarChar(36)
  name           String  @unique @db.NVarChar(100)
  description    String? @db.NVarChar(500)
  isAdmin        Boolean @default(false)
  isSystem       Boolean @default(false) // built-in roles cannot be deleted
  status         String  @default("active") @db.NVarChar(20) // active | deleted
  projectPerms   Int     @default(0)
  testcasePerms  Int     @default(0)
  testrunPerms   Int     @default(0)
  userPerms      Int     @default(0)
  importPerms    Int     @default(0)
  generatePerms  Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userRoles     UserRole[]
  projectRoles  ProjectAccess[] @relation("ProjectAccessRole")

  @@map("roles")
}

model UserRole {
  id     String @id @default(uuid()) @db.NVarChar(36)
  userId String @unique
  roleId String @db.NVarChar(36)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("user_roles")
}

model ProjectAccess {
  id        String   @id @default(uuid()) @db.NVarChar(36)
  userId    String
  projectId String   @db.NVarChar(36)
  roleId    String?  @db.NVarChar(36)   // project-specific role override (null = use global role)
  grantedBy String?  @db.NVarChar(255)
  grantedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role    Role?   @relation("ProjectAccessRole", fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, projectId])
  @@map("project_access")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.NVarChar(Max)
  access_token      String? @db.NVarChar(Max)
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.NVarChar(Max)
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
